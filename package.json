      <div style={{ maxWidth: 560, margin: "0 auto" }}>
        <Reveal><SectionTag text="Contact" /></Reveal>
        <Reveal delay={0.1}><h1 style={{ fontFamily: "'Shippori Mincho', serif", fontSize: "clamp(22px, 3vw, 32px)", color: C.blueDeep, fontWeight: 500, marginBottom: 14 }}>お問い合わせ</h1></Reveal>
        <Reveal delay={0.15}><p style={{ fontSize: 13, color: C.textMuted, lineHeight: 2, fontFamily: "'Noto Sans JP', sans-serif", fontWeight: 300, marginBottom: 40 }}>経営のお悩み、まずはお気軽にご相談ください。初回相談は無料です。</p></Reveal>
        <Reveal delay={0.2}>
          <div style={{ background: C.white, border: `1px solid ${C.border}`, borderRadius: 12, padding: "40px 36px" }}>
            <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
              <div style={{ display: "flex", gap: 16, flexWrap: "wrap" }}>
                <div style={{ flex: "1 1 200px" }}><label style={labelStyle}>お名前 *</label><input style={inputStyle} value={form.name} onChange={set("name")} onFocus={focus} onBlur={blur} /></div>
                <div style={{ flex: "1 1 200px" }}><label style={labelStyle}>貴社名</label><input style={inputStyle} value={form.company} onChange={set("company")} onFocus={focus} onBlur={blur} /></div>
              </div>
              <div style={{ display: "flex", gap: 16, flexWrap: "wrap" }}>
                <div style={{ flex: "1 1 200px" }}><label style={labelStyle}>メールアドレス *</label><input type="email" style={inputStyle} value={form.email} onChange={set("email")} onFocus={focus} onBlur={blur} /></div>
                <div style={{ flex: "1 1 200px" }}><label style={labelStyle}>電話番号</label><input type="tel" style={inputStyle} value={form.phone} onChange={set("phone")} onFocus={focus} onBlur={blur} /></div>
              </div>
              <div><label style={labelStyle}>ご希望の連絡日 *</label><input type="date" style={inputStyle} value={form.date} onChange={set("date")} onFocus={focus} onBlur={blur} /></div>
              <div>
                <label style={labelStyle}>ご相談内容 *</label>
                <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
                  {["経営相談", "次世代自販機", "人材マッチング", "その他"].map(opt => (
                    <button key={opt} onClick={() => setForm(p => ({...p, subject: opt}))} style={{
                      padding: "10px 20px", borderRadius: 6,
                      border: form.subject === opt ? `2px solid ${C.blue}` : `1px solid ${C.border}`,
                      background: form.subject === opt ? C.bluePale : C.white,
                      color: form.subject === opt ? C.blue : C.textMuted,
                      fontSize: 12.5, cursor: "pointer", fontFamily: "'Noto Sans JP', sans-serif",
                      fontWeight: form.subject === opt ? 600 : 300, transition: "all 0.3s",
                    }}>{opt}</button>
                  ))}
                </div>
              </div>
              <div><label style={labelStyle}>備考</label><textarea rows={4} style={{...inputStyle, resize: "vertical"}} value={form.note} onChange={set("note")} onFocus={focus} onBlur={blur} /></div>
              <button onClick={() => setSubmitted(true)} style={{
                background: `linear-gradient(135deg, ${C.blue} 0%, ${C.blueLight} 100%)`,
                color: C.white, border: "none", borderRadius: 6,
                padding: "16px 32px", fontSize: 13.5, fontWeight: 500, cursor: "pointer",
                letterSpacing: "0.1em", fontFamily: "'Noto Sans JP', sans-serif",
                transition: "all 0.3s", marginTop: 4, boxShadow: `0 4px 16px rgba(27,69,114,0.2)`,
              }}
              onMouseEnter={e => e.target.style.transform = "translateY(-1px)"}
              onMouseLeave={e => e.target.style.transform = "translateY(0)"}
              >送信する</button>
            </div>
          </div>
        </Reveal>
      </div>
    </section>
  );
}

// ═══════════════════════════════════════════
// APP
// ═══════════════════════════════════════════
export default function App() {
  const [page, setPage] = useState("home");
